<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/vpOnboarding"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
        android:id="@+id/dotOnboarding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="90dp"
        android:layout_marginBottom="40dp"
        app:dotsColor="#CCCCCC"
        app:dotsSize="10dp"
        app:dotsSpacing="3dp"
        app:progressMode="false"
        app:selectedDotColor="#3B82F6" />

    <TableRow
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/bg_btn_next"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_inter"
            android:text="@string/next"
            android:textColor="@android:color/white"
            android:textFontWeight="730"
            android:textSize="16sp" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_next"
            app:tint="@android:color/white"
            tools:ignore="ContentDescription" />
    </TableRow>

    <TableRow
        android:id="@+id/btn_get_started"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/bg_btn_next"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_inter"
            android:text="@string/txt_get_started"
            android:textColor="@android:color/white"
            android:textFontWeight="730"
            android:textSize="16sp" />

        <ImageView
            android:layout_width="20dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_rocket"
            app:tint="@android:color/white"
            tools:ignore="ContentDescription" />
    </TableRow>


</LinearLayout>