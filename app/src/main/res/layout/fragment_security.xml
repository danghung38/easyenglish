<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_app"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/white"
        android:fontFamily="@font/font_inter"
        android:gravity="start|center_vertical"
        android:paddingStart="20dp"
        android:text="@string/txt_security"
        android:textColor="@color/color_app"
        android:textFontWeight="800"
        android:textSize="24sp"
        tools:ignore="RtlSymmetry,TextSizeCheck" />


    <TableRow
        android:id="@+id/trInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:background="@color/white"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_security"
                tools:ignore="ContentDescription,UnusedAttribute,ImageContrastCheck" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="15dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/font_inter"
                android:gravity="start"
                android:maxLines="1"
                android:text="@string/txt_account_protection"
                android:textColor="@color/black"
                android:textFontWeight="600"
                android:textSize="20sp"
                android:visibility="visible" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:fontFamily="sans-serif-light"
                android:gravity="start"
                android:text="@string/txt_des_security"
                android:textColor="@color/color_splash_des"
                android:textFontWeight="450"
                android:textSize="13sp"
                tools:ignore="TextContrastCheck" />
        </LinearLayout>

    </TableRow>


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="15dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font_inter"
                android:text="@string/txt_security_password"
                android:textColor="@color/color_text_app"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:ignore="TextContrastCheck" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:fontFamily="sans-serif-light"
                android:gravity="start"
                android:text="@string/txt_des_security_2"
                android:textColor="@color/color_splash_des"
                android:textFontWeight="400"
                android:textSize="13sp"
                tools:ignore="TextContrastCheck" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/font_inter"
                    android:text="@string/txt_current_password"
                    android:textColor="@color/color_text_profile"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_edt_register"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="20dp"
                        android:src="@drawable/ic_password"
                        app:tint="@color/color_splash_des"
                        tools:ignore="ContentDescription,ImageContrastCheck" />

                    <EditText
                        android:id="@+id/edtOldPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:autofillHints="@string/txt_password_bycrypt"
                        android:background="@android:color/transparent"
                        android:fontFamily="sans-serif-light"
                        android:gravity="center_vertical"
                        android:hint="@string/txt_password_bycrypt"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textColor="@color/color_text_app"
                        android:textColorHint="@color/color_splash_des"
                        android:textFontWeight="400"
                        android:textSize="14sp"
                        tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                </TableRow>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/font_inter"
                    android:text="@string/txt_new_password"
                    android:textColor="@color/color_text_profile"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_edt_register"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="20dp"
                        android:src="@drawable/ic_password"
                        app:tint="@color/color_splash_des"
                        tools:ignore="ContentDescription,ImageContrastCheck" />

                    <EditText
                        android:id="@+id/edtNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:autofillHints="@string/txt_password_bycrypt"
                        android:background="@android:color/transparent"
                        android:fontFamily="sans-serif-light"
                        android:gravity="center_vertical"
                        android:hint="@string/txt_password_bycrypt"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textColor="@color/color_text_app"
                        android:textColorHint="@color/color_splash_des"
                        android:textFontWeight="400"
                        android:textSize="14sp"
                        tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                </TableRow>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="start"
                    android:text="@string/txt_des_security_3"
                    android:textColor="@color/color_splash_des"
                    android:textFontWeight="400"
                    android:textSize="11sp"
                    tools:ignore="TextContrastCheck" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/font_inter"
                    android:text="@string/txt_confirm_password"
                    android:textColor="@color/color_text_profile"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_edt_register"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="5dp"
                        android:layout_marginEnd="20dp"
                        android:src="@drawable/ic_confirm_pass"
                        app:tint="@color/color_splash_des"
                        tools:ignore="ContentDescription,ImageContrastCheck" />

                    <EditText
                        android:id="@+id/edtConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:autofillHints="@string/txt_password_bycrypt"
                        android:background="@android:color/transparent"
                        android:fontFamily="sans-serif-light"
                        android:gravity="center_vertical"
                        android:hint="@string/txt_password_bycrypt"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:textColor="@color/color_text_app"
                        android:textColorHint="@color/color_splash_des"
                        android:textFontWeight="400"
                        android:textSize="14sp"
                        tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                </TableRow>
            </LinearLayout>

            <TextView
                android:id="@+id/btnUpdatePassword"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_btn_register"
                android:fontFamily="@font/font_inter"
                android:gravity="center"
                android:paddingBottom="30dp"
                android:text="@string/txt_update_password"
                android:textColor="@android:color/white"
                android:textFontWeight="730"
                android:textSize="16sp"
                tools:ignore="VisualLintBounds" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <TableRow
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="15dp"
        android:background="@drawable/bg_btn_logout"
        android:gravity="center"
        android:paddingHorizontal="20dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_logout"
            tools:ignore="ContentDescription" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_inter"
            android:gravity="center"
            android:text="@string/txt_logout"
            android:textColor="@color/color_logout"
            android:textFontWeight="730"
            android:textSize="16sp"
            tools:ignore="VisualLintBounds" />
    </TableRow>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:text="@string/txt_des_logout"
        android:textColor="@color/color_splash_des"
        android:textFontWeight="400"
        android:textSize="11sp"
        tools:ignore="TextContrastCheck" />


</LinearLayout>




