<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_app"
    android:orientation="vertical">

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/white">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical"
            android:padding="7dp"
            android:src="@drawable/ic_back"
            tools:ignore="ContentDescription" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_marginEnd="56dp"
            android:layout_weight="1"
            android:fontFamily="@font/font_inter"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/color_app"
            android:textFontWeight="800"
            android:textSize="24sp"
            tools:ignore="TextSizeCheck" />
    </TableRow>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/color_bg_app"
        android:orientation="vertical"
        android:paddingHorizontal="25dp">

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:src="@drawable/ic_logo_register"
            tools:ignore="ContentDescription" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:layout_marginTop="-15dp"
            android:fontFamily="@font/font_inter"
            android:gravity="center"
            android:text="@string/txt_create_account"
            android:textFontWeight="800"
            android:textSize="26sp"
            tools:ignore="TextSizeCheck" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="40dp"
            android:fontFamily="sans-serif-light"
            android:text="@string/txt_des_register"
            android:textColor="@color/color_des_login"
            android:textFontWeight="400"
            android:textSize="16sp"
            tools:ignore="TextContrastCheck" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none"
            tools:ignore="NestedWeights">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_full_name"
                        android:textColor="@color/color_text_app"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_user"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtFullName"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:autofillHints="@string/txt_des_full_name"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_full_name"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="370"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_username"
                        android:textColor="@color/color_text_app"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_username"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtUsername"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:autofillHints="@string/txt_des_username"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_username"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="370"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_email_address"
                        android:textColor="@color/color_text_app"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_mail"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtEmail"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:autofillHints="@string/txt_des_mail"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_mail"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="370"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_phone_number"
                        android:textColor="@color/color_text_app"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtPhoneNumber"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:autofillHints="@string/txt_des_phone_number"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_phone_number"
                            android:inputType="phone"
                            android:maxLines="1"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="370"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_gender"
                        android:textColor="@color/color_text_app"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <!-- icon -->
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_gender"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <!-- spinner -->
                        <Spinner
                            android:id="@+id/spGender"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical"
                            android:spinnerMode="dropdown"
                            tools:entries="@array/gender_list"
                            tools:selectedItemPosition="0" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_date_of_birth"
                        android:textColor="@color/color_text_app"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_date"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtDateOfBirth"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:autofillHints="@string/txt_des_date"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_date"
                            android:inputType="date"
                            android:maxLines="1"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="370"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_password"
                        android:textColor="@color/color_text_app"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_password"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtPassword"

                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:autofillHints="@string/txt_des_password"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_password"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="370"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_confirm_password"
                        android:textColor="@color/color_text_app"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_confirm_pass"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtConfirmPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:autofillHints="@string/txt_des_confirm_password"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_confirm_password"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="370"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="25dp"
                    android:background="@drawable/bg_btn_register"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:paddingBottom="30dp"
                    android:text="@string/txt_sign_up"
                    android:textColor="@android:color/white"
                    android:textFontWeight="730"
                    android:textSize="16sp" />

            </LinearLayout>
        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_line" />

        <TextView
            android:id="@+id/tvHaveAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|bottom"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="25dp"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/font_inter"
            android:gravity="center"
            android:text="@string/txt_have_account"
            tools:ignore="TextContrastCheck,TouchTargetSizeCheck" />

    </LinearLayout>

</LinearLayout>


