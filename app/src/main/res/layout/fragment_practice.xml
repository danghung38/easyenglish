<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="@color/color_bg_app"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TableRow
        android:layout_width="match_parent"
        android:background="@color/white"
        android:paddingHorizontal="20dp"
        android:paddingVertical="15dp"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvTitleExam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font_inter"
                android:gravity="start"
                android:maxLines="2"
                android:text="@string/txt_title_exam"
                android:textColor="@color/black"
                android:textFontWeight="600"
                android:textSize="20sp"
                android:visibility="visible" />
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:layout_marginEnd="5dp"
                    android:src="@drawable/ic_duration"
                    tools:ignore="ContentDescription,ImageContrastCheck" />

                <TextView
                    android:id="@+id/tvDurationExam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="sans-serif-light"
                    android:gravity="start"
                    android:maxLines="2"
                    android:text="@string/txt_duration"
                    android:textColor="@color/color_text_profile"
                    android:textFontWeight="450"
                    android:textSize="13sp"
                    tools:ignore="TextContrastCheck" />
            </TableRow>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_gravity="top|end"
            android:padding="3dp"
            android:src="@drawable/ic_close"
            tools:ignore="ContentDescription" />
    </TableRow>



    <LinearLayout
        android:padding="20dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ic_full_test"
                        tools:ignore="ContentDescription" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="10dp"
                        tools:ignore="RtlSymmetry">

                        <TableRow
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:layout_marginEnd="5dp"
                                android:src="@drawable/ic_bagde"
                                tools:ignore="ContentDescription,ImageContrastCheck" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@color/white"
                                android:fontFamily="@font/font_inter"
                                android:gravity="start|center_vertical"
                                android:text="@string/txt_full_test"
                                android:textColor="@color/color_app"
                                android:textFontWeight="700"
                                android:textSize="22sp"
                                tools:ignore="RtlSymmetry,TextSizeCheck" />
                        </TableRow>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="sans-serif-light"
                            android:gravity="start"
                            android:maxLines="1"
                            android:text="@string/txt_des_full_test"
                            android:textColor="@color/color_splash_des"
                            android:textFontWeight="450"
                            android:textSize="13sp"
                            tools:ignore="TextContrastCheck" />


                    </LinearLayout>

                </TableRow>

                <TableRow
                    android:layout_marginTop="15dp"
                    android:layout_width="match_parent"
                    android:gravity="center"
                    android:layout_height="wrap_content">

                    <TableRow
                        android:background="@drawable/bg_skill"
                        android:layout_weight="1"
                        android:paddingVertical="2dp"
                        android:layout_width="0dp"
                        android:backgroundTint="@color/color_bg_listening3"
                        android:gravity="center"
                        android:layout_marginEnd="15dp"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/font_inter"
                            android:gravity="center"
                            android:text="@string/txt_listening"
                            android:textColor="@color/color_bg_listening"
                            android:textFontWeight="600"
                            android:textSize="12sp"
                            tools:ignore="TextContrastCheck" />

                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_listening3"
                            android:layout_marginStart="5dp"
                            tools:ignore="ContentDescription,ImageContrastCheck" />
                    </TableRow>

                    <TableRow
                        android:background="@drawable/bg_skill"
                        android:layout_weight="1"
                        android:paddingVertical="2dp"
                        android:layout_width="0dp"
                        android:backgroundTint="@color/color_bg_reading3"
                        android:gravity="center"
                        android:layout_marginEnd="15dp"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/font_inter"
                            android:gravity="center"
                            android:text="@string/txt_reading"
                            android:textColor="@color/color_bg_reading"
                            android:textFontWeight="600"
                            android:textSize="12sp"
                            tools:ignore="TextContrastCheck" />

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_reading3"
                            android:layout_marginStart="5dp"
                            app:tint="@color/color_bg_reading"
                            tools:ignore="ContentDescription,ImageContrastCheck" />
                    </TableRow>

                    <TableRow
                        android:background="@drawable/bg_skill"
                        android:layout_weight="1"
                        android:paddingVertical="2dp"
                        android:layout_width="0dp"
                        android:backgroundTint="@color/color_bg_speaking3"
                        android:gravity="center"
                        android:layout_marginEnd="15dp"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/font_inter"
                            android:gravity="center"
                            android:text="@string/txt_speaking"
                            android:textColor="@color/color_bg_speaking"
                            android:textFontWeight="600"
                            android:textSize="12sp"
                            tools:ignore="TextContrastCheck" />

                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_speaking3"
                            android:layout_marginStart="5dp"
                            app:tint="@color/color_bg_speaking"
                            tools:ignore="ContentDescription,ImageContrastCheck" />
                    </TableRow>

                    <TableRow
                        android:background="@drawable/bg_skill"
                        android:layout_weight="1"
                        android:paddingVertical="2dp"
                        android:layout_width="0dp"
                        android:backgroundTint="@color/color_bg_writing3"
                        android:gravity="center"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/font_inter"
                            android:gravity="center"
                            android:text="@string/txt_writing"
                            android:textColor="@color/color_bg_writing"
                            android:textFontWeight="600"
                            android:textSize="12sp"
                            tools:ignore="TextContrastCheck" />

                        <ImageView
                            android:layout_width="11dp"
                            android:layout_height="11dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_writing3"
                            android:layout_marginStart="5dp"
                            app:tint="@color/color_bg_writing"
                            tools:ignore="ContentDescription,ImageContrastCheck" />
                    </TableRow>

                </TableRow>

                <TableRow
                    android:id="@+id/btnStartFullTest"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="30dp"
                    android:background="@drawable/bg_start_test"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="24dp"
                        android:padding="5dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="1dp"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/ic_start_full"
                        app:tint="@android:color/white"
                        tools:ignore="ContentDescription" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:fontFamily="@font/font_inter"
                        android:gravity="center"
                        android:text="@string/txt_start_full_test_now"
                        android:textColor="@android:color/white"
                        android:textFontWeight="730"
                        android:textSize="16sp" />

                </TableRow>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TableRow
            android:layout_marginVertical="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:layout_height="1dp"
                android:background="@color/color_splash_des"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:fontFamily="@font/font_inter"
                android:text="@string/txt_or"
                android:textColor="@color/color_splash_des"
                android:textFontWeight="700"
                android:textSize="16sp"
                tools:ignore="TextContrastCheck" />

            <View
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:layout_height="1dp"
                android:background="@color/color_splash_des"/>
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:gravity="center"
            android:layout_height="wrap_content">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_part"
                app:tint="@color/color_app"
                tools:ignore="ContentDescription,ImageContrastCheck" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font_inter"
                android:gravity="center"
                android:text="@string/txt_sections"
                android:textColor="@color/color_app"
                android:textFontWeight="700"
                android:textSize="20sp"
                tools:ignore="RtlSymmetry,TextSizeCheck" />
        </TableRow>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/txt_des_sections"
            android:textColor="@color/color_splash_des"
            android:textFontWeight="450"
            android:textSize="13sp"
            tools:ignore="TextContrastCheck" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp">

            <LinearLayout
                android:id="@+id/btnStartListening"
                android:layout_width="0dp"
                android:layout_height="170dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/bg_ic_home"
                android:orientation="vertical"
                android:padding="15dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_listening2"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="25dp"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:text="@string/txt_listening"
                    android:textFontWeight="600"
                    android:textSize="20sp"
                    tools:ignore="TextSizeCheck" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:text="@string/txt_des_listening"
                    android:textColor="@color/color_splash_des"
                    android:textFontWeight="450"
                    android:textSize="11sp"
                    tools:ignore="TextContrastCheck" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnStartReading"
                android:layout_width="0dp"
                android:gravity="center"
                android:layout_height="170dp"
                android:layout_weight="1"
                android:background="@drawable/bg_ic_home"
                android:orientation="vertical"
                android:padding="15dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_reading2"
                    tools:ignore="ContentDescription,ImageContrastCheck" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="25dp"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:text="@string/txt_reading"
                    android:textFontWeight="600"
                    android:textSize="20sp"
                    tools:ignore="TextSizeCheck" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:text="@string/txt_des_reading"
                    android:textColor="@color/color_splash_des"
                    android:textFontWeight="450"
                    android:textSize="11sp"
                    tools:ignore="TextContrastCheck" />
            </LinearLayout>


        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:id="@+id/btnStartSpeaking"
                android:layout_width="0dp"
                android:layout_height="170dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_ic_home"
                android:orientation="vertical"
                android:padding="15dp"
                android:gravity="center"
                tools:ignore="VisualLintBounds">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_speaking2"
                    tools:ignore="ContentDescription,ImageContrastCheck" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="25dp"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:text="@string/txt_speaking"
                    android:textFontWeight="600"
                    android:textSize="20sp"
                    tools:ignore="TextSizeCheck" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:text="@string/txt_des_speaking"
                    android:textColor="@color/color_splash_des"
                    android:textFontWeight="450"
                    android:textSize="11sp"
                    tools:ignore="TextContrastCheck" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnStartWriting"
                android:layout_width="0dp"
                android:layout_height="170dp"
                android:layout_weight="1"
                android:background="@drawable/bg_ic_home"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="15dp"
                tools:ignore="VisualLintBounds">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@drawable/ic_writing2"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="25dp"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:text="@string/txt_writing"
                    android:textFontWeight="600"
                    android:textSize="20sp"
                    tools:ignore="TextSizeCheck" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:text="@string/txt_des_writing"
                    android:textColor="@color/color_splash_des"
                    android:textFontWeight="450"
                    android:textSize="11sp"
                    tools:ignore="TextContrastCheck" />
            </LinearLayout>


        </TableRow>


    </LinearLayout>


</LinearLayout>