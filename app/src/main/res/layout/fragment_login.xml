<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_app"
    android:orientation="vertical"
    android:paddingHorizontal="25dp"
    tools:ignore="UselessParent">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:src="@drawable/ic_logo_login"
        tools:ignore="ContentDescription,ImageContrastCheck" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_gravity="center"
        android:layout_marginTop="-10dp"
        android:fontFamily="@font/font_inter"
        android:gravity="center"
        android:text="@string/txt_splash"
        android:textFontWeight="800"
        android:textSize="26sp"
        tools:ignore="TextSizeCheck,TextContrastCheck" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="40dp"
        android:fontFamily="sans-serif-light"
        android:text="@string/txt_des_login"
        android:textColor="@color/color_des_login"
        android:textFontWeight="400"
        android:textSize="16sp"
        tools:ignore="TextContrastCheck" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="15dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/font_inter"
            android:text="@string/txt_username"
            android:textColor="@color/color_text_app"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:ignore="TextContrastCheck" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edt_login"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="20dp"
                android:src="@drawable/ic_user"
                app:tint="@color/color_splash_des"
                tools:ignore="ContentDescription,ImageContrastCheck" />

            <EditText
                android:id="@+id/edtUsername"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:autofillHints="@string/txt_username"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif-light"
                android:gravity="center_vertical"
                android:hint="@string/txt_username"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/color_text_app"
                android:textColorHint="@color/color_splash_des"
                android:textFontWeight="370"
                android:textSize="14sp"
                tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
        </TableRow>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/font_inter"
            android:text="@string/txt_password"
            android:textColor="@color/color_text_app"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_edt_login"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="20dp"
                android:src="@drawable/ic_password"
                app:tint="@color/color_splash_des"
                tools:ignore="ContentDescription,ImageContrastCheck" />

            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:autofillHints="@string/txt_password_bycrypt"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif-light"
                android:gravity="center_vertical"
                android:hint="@string/txt_password_bycrypt"
                android:inputType="textPassword"
                android:maxLines="1"
                android:textColor="@color/color_text_app"
                android:textColorHint="@color/color_splash_des"
                android:textFontWeight="370"
                android:textSize="14sp"
                tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
        </TableRow>
    </LinearLayout>

    <TextView
        android:id="@+id/tvForgotPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginVertical="5dp"
        android:layout_marginBottom="40dp"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/font_inter"
        android:text="@string/txt_forgot_password"
        android:textColor="@color/color_app"
        android:textSize="16sp"
        tools:ignore="TextContrastCheck,TouchTargetSizeCheck" />

    <TextView
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginHorizontal="5dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_btn_next"
        android:fontFamily="@font/font_inter"
        android:gravity="center"
        android:text="@string/txt_login"
        android:textColor="@android:color/white"
        android:textFontWeight="730"
        android:textSize="16sp"
        tools:ignore="TextContrastCheck" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="25dp"
        android:fontFamily="@font/font_inter"
        android:text="@string/txt_or_login_with"
        android:textColor="@color/color_splash_des"
        android:textSize="13sp"
        tools:ignore="TextContrastCheck" />

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TableRow
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginEnd="30dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_more"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_google"
                tools:ignore="ContentDescription,ImageContrastCheck" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font_inter"
                android:text="@string/txt_google"
                android:textColor="@color/color_text_app"
                android:textFontWeight="730"
                android:textSize="16sp"
                tools:ignore="TextContrastCheck" />
        </TableRow>

        <TableRow
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_more"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_fb"
                tools:ignore="ContentDescription,ImageContrastCheck" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font_inter"
                android:text="@string/tx_fb"
                android:textColor="@color/color_text_app"
                android:textFontWeight="730"
                android:textSize="16sp"
                tools:ignore="TextContrastCheck" />
        </TableRow>
    </TableRow>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center">

        <TextView
            android:id="@+id/tvSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|bottom"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/font_inter"
            android:gravity="center"
            android:text="@string/txt_no_account"
            tools:ignore="TextContrastCheck,TouchTargetSizeCheck" />
    </LinearLayout>


</LinearLayout>

