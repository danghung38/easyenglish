<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/iv_onboarding"
        android:layout_width="match_parent"
        android:paddingHorizontal="35dp"
        android:layout_height="0dp"
        android:layout_marginBottom="-80dp"
        android:layout_weight="1"
        android:src="@drawable/ic_onboarding1"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_title_onboarding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/font_inter"
        android:gravity="center"
        android:text="@string/onboarding_title_1"
        android:textColor="@color/black"
        android:textFontWeight="800"
        android:textSize="26sp"
        tools:ignore="TextSizeCheck" />

    <TextView
        android:id="@+id/tv_desc_onboarding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:padding="10dp"
        android:text="@string/onboarding_desc_1"
        android:textColor="@color/color_splash_des"
        android:textFontWeight="400"
        android:textSize="16sp"
        tools:ignore="TextContrastCheck" />

</LinearLayout>