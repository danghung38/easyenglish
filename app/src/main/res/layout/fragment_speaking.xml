<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:background="@color/color_bg_app"
    android:layout_height="match_parent">

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="@color/white">

        <TableRow
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent">

            <ImageView
                android:layout_width="24dp"
                android:layout_gravity="center"
                android:layout_height="24dp"
                android:src="@drawable/ic_timer"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_time_reading"
                android:layout_marginStart="5dp"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:fontFamily="@font/font_inter"
                android:textFontWeight="730" />
        </TableRow>

        <TableRow
            android:layout_width="0dp"
            android:gravity="end"
            android:layout_weight="1"
            android:layout_height="match_parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_speaking_test"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:layout_gravity="center"
                android:fontFamily="@font/font_inter"
                android:textFontWeight="730" />
        </TableRow>

    </TableRow>

    <TextView
        android:id="@+id/tvSpeakingQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txt_writing_instruction"
        android:textColor="@color/black"
        android:textFontWeight="500"
        android:textSize="15sp"
        android:paddingVertical="10dp"
        android:paddingHorizontal="20dp"
        android:fontFamily="@font/font_inter" />

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp">
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:fontFamily="@font/font_inter"
            android:gravity="start"
            android:text="@string/txt_your_answer"
            android:textColor="@color/color_text_app"
            android:textFontWeight="600"
            android:textSize="16sp"
            android:visibility="visible" />


    </TableRow>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="20dp"
            android:background="@color/color_app"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            tools:ignore="NestedWeights">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/color_app"
                android:gravity="center"
                android:minHeight="250dp"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivRecordAnswer"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_record"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/tvRecordingStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:paddingHorizontal="20dp"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:text="@string/txt_answer_speaking"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>



        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableRow
                android:id="@+id/btnStartRecording"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:layout_marginEnd="40dp"
                android:background="@drawable/bg_btn_record"
                android:backgroundTint="@color/color_start"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="1dp"
                    android:layout_marginEnd="5dp"
                    android:padding="5dp"
                    android:src="@drawable/ic_start_full"
                    app:tint="@android:color/white"
                    tools:ignore="ContentDescription,ImageContrastCheck" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:text="@string/txt_start_recording"
                    android:textColor="@android:color/white"
                    android:textFontWeight="730"
                    android:textSize="16sp"
                    tools:ignore="TextContrastCheck" />

            </TableRow>
            <TableRow
                android:id="@+id/btnStopRecording"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_record"
                android:backgroundTint="@color/color_stop"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:text="@string/txt_stop"
                    android:textColor="@android:color/white"
                    android:textFontWeight="730"
                    android:textSize="16sp" />

            </TableRow>

        </TableRow>

    </LinearLayout>

    <TableRow
        android:id="@+id/btnSubmitSpeaking"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_start_test"
        android:backgroundTint="@color/color_submit"
        android:gravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:layout_marginTop="1dp"
            android:layout_marginEnd="5dp"
            android:src="@drawable/ic_start_test"
            app:tint="@android:color/white"
            tools:ignore="ContentDescription" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/font_inter"
            android:gravity="center"
            android:text="@string/txt_submit"
            android:textColor="@android:color/white"
            android:textFontWeight="730"
            android:textSize="16sp" />

    </TableRow>

</LinearLayout>