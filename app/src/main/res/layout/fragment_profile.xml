<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_app"
    android:orientation="vertical">

    <TableRow
        android:id="@+id/trInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="20dp">

        <FrameLayout
            android:id="@+id/frAvatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:background="@drawable/bg_circle"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_avt"
                tools:ignore="ContentDescription,UnusedAttribute,ImageContrastCheck" />

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="end|bottom"
                android:src="@drawable/ic_edit_avt"
                tools:ignore="ContentDescription" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="20dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/font_inter"
                android:gravity="start"
                android:maxLines="1"
                android:text="@string/txt_name_profile"
                android:textColor="@color/black"
                android:textFontWeight="600"
                android:textSize="20sp"
                android:visibility="visible" />

            <TableRow
                android:id="@+id/trSecurity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@color/white">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_security"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_marginEnd="5dp"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:text="@string/txt_security"
                    android:textColor="@color/color_app"
                    android:textFontWeight="600"
                    android:textSize="16sp"
                    tools:ignore="TextSizeCheck" />

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_goto"
                    tools:ignore="ContentDescription,ImageContrastCheck" />
            </TableRow>
        </LinearLayout>

    </TableRow>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbars="none">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingVertical="10dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_inter"
                    android:text="@string/txt_info_account"
                    android:textColor="@color/color_text_app"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:ignore="TextContrastCheck" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="start"
                    android:text="@string/txt_des_info_account"
                    android:textColor="@color/color_splash_des"
                    android:textFontWeight="400"
                    android:textSize="13sp"
                    tools:ignore="TextContrastCheck" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_full_name"
                        android:textColor="@color/color_text_profile"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_user"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtFullName"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:autofillHints="@string/txt_des_full_name"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_full_name"
                            android:inputType="text"
                            android:maxLines="1"
                            android:text="@string/txt_name_profile"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="400"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_email_address"
                        android:textColor="@color/color_text_profile"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_edt_not_edit"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_username"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <TextView
                            android:id="@+id/tvEmail"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:maxLines="1"
                            android:text="@string/txt_des_mail"
                            android:textColor="@color/color_text_profile"
                            android:textFontWeight="400"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_phone_number"
                        android:textColor="@color/color_text_profile"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_edt_not_edit"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <TextView
                            android:id="@+id/tvPhone"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:maxLines="1"
                            android:text="@string/txt_des_phone_number"
                            android:textColor="@color/color_text_profile"
                            android:textFontWeight="400"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_date_of_birth"
                        android:textColor="@color/color_text_profile"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginStart="5dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_date"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <EditText
                            android:id="@+id/edtDateOfBirth"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:autofillHints="@string/txt_des_date"
                            android:background="@android:color/transparent"
                            android:fontFamily="sans-serif-light"
                            android:gravity="center_vertical"
                            android:hint="@string/txt_des_date"
                            android:inputType="date"
                            android:maxLines="1"
                            android:text="@string/txt_dob"
                            android:textColor="@color/color_text_app"
                            android:textColorHint="@color/color_splash_des"
                            android:textFontWeight="400"
                            android:textSize="14sp"
                            tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical"
                    tools:ignore="ExtraText">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_gender"
                        android:textColor="@color/color_text_profile"
                        android:textSize="14sp"
                        android:textStyle="bold" />>

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_gender"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <!-- spinner -->
                        <Spinner
                            android:id="@+id/spGender"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical"
                            android:spinnerMode="dropdown"
                            tools:entries="@array/gender_list"
                            tools:selectedItemPosition="0" />
                    </TableRow>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="@font/font_inter"
                        android:text="@string/txt_target"
                        android:textColor="@color/color_text_profile"
                        android:textSize="14sp"
                        android:textStyle="bold" />>

                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_edt_register"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        tools:ignore="VisualLintBounds">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="20dp"
                            android:src="@drawable/ic_rocket"
                            app:tint="@color/color_splash_des"
                            tools:ignore="ContentDescription,ImageContrastCheck" />

                        <Spinner
                            android:id="@+id/spTarget"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical"
                            android:spinnerMode="dropdown"
                            tools:entries="@array/target_list"
                            tools:ignore="TouchTargetSizeCheck"
                            tools:selectedItemPosition="0" />
                    </TableRow>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnUpdate"
                    android:layout_width="match_parent"
                    android:layout_height="84dp"
                    android:layout_marginTop="25dp"
                    android:background="@drawable/bg_btn_register"
                    android:fontFamily="@font/font_inter"
                    android:gravity="center"
                    android:paddingBottom="30dp"
                    android:text="@string/txt_update"
                    android:textColor="@android:color/white"
                    android:textFontWeight="730"
                    android:textSize="16sp"
                    tools:ignore="VisualLintBounds" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>



