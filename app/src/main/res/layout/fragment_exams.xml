<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_app"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="20dp">

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@drawable/bg_search"
            android:gravity="center_vertical"
            android:paddingHorizontal="15dp">

            <EditText
                android:id="@+id/edtSearchExams"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:autofillHints="@string/txt_search_exams"
                android:background="@android:color/transparent"
                android:fontFamily="sans-serif-light"
                android:gravity="center_vertical"
                android:hint="@string/txt_search_exams"
                android:inputType="text"
                android:maxLines="1"
                android:paddingHorizontal="15dp"
                android:textColor="@color/color_text_app"
                android:textColorHint="@color/color_splash_des"
                android:textFontWeight="400"
                android:textSize="14sp"
                tools:ignore="TextContrastCheck,VisualLintTextFieldSize,DuplicateSpeakableTextCheck,TouchTargetSizeCheck" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="15dp"
                android:elevation="5dp"
                android:src="@drawable/ic_search"
                tools:ignore="ContentDescription,ImageContrastCheck" />


        </TableRow>

    </FrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAllExams"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp"
        android:visibility="visible"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_exam" />


</LinearLayout>


